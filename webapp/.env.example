# Configuration du MOTEUR DE RENDU (tourne sur le PC)
# Copie ce fichier en .env et ajuste si besoin.

# Port d'écoute local du moteur
PORT=4000

# Dossier racine des mockups (structure : mockups/<type>/<categorie>/<sous-cat>/<orientation>.psd)
MOCKUPS_PATH=C:\Users\gueta\Downloads\mockups

